import java.util.Scanner;

class Livro {
    private String titulo;
    private int paginas;

    public Livro(String titulo, int paginas) {
        this.titulo = titulo;
        this.paginas = paginas;
    }

    public String getTitulo() {
        return titulo;
    }

    public int getPaginas() {
        return paginas;
    }

    public void setPaginas(int paginas) {
        this.paginas = paginas;
    }
}

public class Main {
    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        System.out.print("Digite o título do livro: ");
        String titulo = scanner.nextLine();

        System.out.print("Digite o número de páginas: ");
        int paginas = scanner.nextInt();

        Livro livro1 = new Livro(titulo, paginas);

        System.out.println("\nDados do livro:");
        System.out.println("Título: " + livro1.getTitulo());
        System.out.println("Páginas: " + livro1.getPaginas());

        System.out.print("\nDigite o novo número de páginas: ");
        int novasPaginas = scanner.nextInt();
        livro1.setPaginas(novasPaginas);

        System.out.println("Páginas atualizadas: " + livro1.getPaginas());

        scanner.close();
    }
}
