import java.util.Scanner;

class Estudante {
    private String nome;
    private int idade;

    public Estudante(String nome, int idade) {
        this.nome = nome;
        this.idade = idade;
    }

    public String getNome() {
        return nome;
    }

    public int getIdade() {
        return idade;
    }

    public void setIdade(int idade) {
        this.idade = idade;
    }
}

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Digite o nome: ");
        String nome = sc.nextLine();

        System.out.print("Digite a idade: ");
        int idade = sc.nextInt();

        Estudante e = new Estudante(nome, idade);

        System.out.println("\nNome: " + e.getNome());
        System.out.println("Idade: " + e.getIdade());

        System.out.print("\nDigite a nova idade: ");
        int novaIdade = sc.nextInt();
        e.setIdade(novaIdade);

        System.out.println("Nova idade: " + e.getIdade());

        sc.close();
    }
}
